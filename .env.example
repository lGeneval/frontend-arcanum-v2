# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google
NEXT_PUBLIC_GOOGLE_LINK_REDIRECT_URI=http://localhost:3000/api/auth/link-google/callback

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_ID=your-telegram-bot-id

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bot API Secret (для генерации ссылок)
BOT_API_SECRET=your-bot-api-secret
